alias configize_md='(echo "```php"; find config -type f -name '\''*.php'\'' -print0 | sort -z | xargs -0 -I{} sh -c '\''echo "// ===== {} ====="; cat "{}"'\''; echo "```") > all_config.md'

# Dump meta files (composer.json + helpers)
alias metaize='(echo "// ===== composer.json ====="; cat composer.json; echo ""; echo "// ===== app/helpers.php ====="; cat app/helpers.php) > meta_output.txt'
alias metaize_md='(echo "```json"; echo "// ===== composer.json ====="; cat composer.json; echo ""; echo "```"; echo ""; echo "```php"; echo "// ===== app/helpers.php ====="; cat app/helpers.php; echo "```") > meta_output.md'

# Dump Blade views (takes a directory argument)
viewize() {
  dir="$1"
  if [[ -z "$dir" ]]; then echo "Usage: viewize <directory>"; return 1; fi
  find "$dir" -type f -name '*.blade.php' -print0 | sort -z | xargs -0 -I{} sh -c 'echo "{{-- ===== {} ===== --}}"; cat "{}"' > all_views.txt
}

viewize_md() {
  dir="$1"
  if [[ -z "$dir" ]]; then echo "Usage: viewize_md <directory>"; return 1; fi
  (echo '```blade'; find "$dir" -type f -name '*.blade.php' -print0 | sort -z | xargs -0 -I{} sh -c 'echo "{{-- ===== {} ===== --}}"; cat "{}"'; echo '```') > all_views.md
}

# Dump EVERYTHING for AI context
dumpall() {
  echo "Dumping all Laravel files for AI context..."
  modelize_md 2>/dev/null; echo "  Models done"
  controllerize_md 2>/dev/null; echo "  Controllers done"
  routeize_md 2>/dev/null; echo "  Routes done"
  middlewareize_md 2>/dev/null; echo "  Middleware done"
  servicize_md 2>/dev/null; echo "  Services done"
  configize_md 2>/dev/null; echo "  Config done"
  metaize_md 2>/dev/null; echo "  Meta done"
  echo "Done! Check all_*.md and meta_output.md"
}

