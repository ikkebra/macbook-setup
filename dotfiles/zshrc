# Dump all models to a single file
alias modelize='find app/Models -type f -name '\''*.php'\'' -print0 | sort -z | xargs -0 -I{} sh -c '\''echo "// ===== {} ====="; awk "!/^<\\?php$/" "{}"'\'' > all_models.txt'
alias modelize_md='(echo "```php"; find app/Models -type f -name '\''*.php'\'' -print0 | sort -z | xargs -0 -I{} sh -c '\''echo "// ===== {} ====="; awk "!/^<\\?php$/" "{}"'\''; echo "```") > all_models.md'

