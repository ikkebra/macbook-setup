alias servicize_md='(echo "```php"; find app/Services -type f -name '\''*.php'\'' -print0 | sort -z | xargs -0 -I{} sh -c '\''echo "// ===== {} ====="; awk "!/^<\\?php$/" "{}"'\''; echo "```") > all_services.md'

# Dump all config
